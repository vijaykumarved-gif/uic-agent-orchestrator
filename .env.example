# ============ CORE (required) ============
DATABASE_URL=postgres://user:pass@host:5432/dbname
REDIS_URL=redis://default:pass@host:6379
CLAUDE_API_KEY=sk-ant-...
NODE_ENV=production

# ============ MEDIA STORAGE (required for any media agent) ============
# Meta/YouTube/LinkedIn publish by FETCHING a public URL — generated media
# must be hosted somewhere reachable. Cloudinary free tier is plenty.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============ IMAGE + SUBTITLE (OpenAI) ============
# Used by: image_agent, thumbnail_agent (gpt-image-1), subtitle_agent (whisper-1)
OPENAI_API_KEY=sk-...

# ============ VOICE (ElevenLabs) ============
# elevenlabs.io -> sign up (free tier: ~10 min audio/month) -> Profile -> API key
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=       # optional; pick a voice in Voice Library and paste its ID
VOICE_LANGUAGE=en          # en | hi (Hinglish scripts work fine with either)

# ============ VIDEO ============
# Option A (recommended): HeyGen — a talking AI presenter speaks your script,
# lip-synced to the ElevenLabs voiceover. heygen.com -> Settings -> API.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=          # optional; copy any avatar's ID from HeyGen, else first avatar is used

# Option B (fallback): Creatomate — image slideshow + voiceover + subtitles.
# If both keys are set, HeyGen (avatar) is used.
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_ID=    # optional; falls back to an inline 9:16 composition

# ============ META (Instagram + Facebook + Competitor + Analytics) ============
META_GRAPH_API_TOKEN=          # long-lived token, needs instagram_content_publish
META_IG_BUSINESS_ID=           # IG Business account id
META_PAGE_ACCESS_TOKEN=        # PAGE token (not user token) for Facebook
META_PAGE_ID=
COMPETITOR_HANDLES=            # comma-separated, e.g. handle1,handle2

# ============ YOUTUBE SHORTS ============
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ============ LINKEDIN ============
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# ============ WHATSAPP (WATI) ============
WATI_API_KEY=
WATI_BASE_URL=https://live-server-xxxxx.wati.io

# ============ DASHBOARD (required - app is on a public URL) ============
DASHBOARD_PASSWORD=choose-a-strong-password
DASHBOARD_SECRET=any-long-random-string-for-signing-cookies
