# ============ CORE (required) ============
DATABASE_URL=postgres://user:pass@host:5432/dbname
REDIS_URL=redis://default:pass@host:6379
CLAUDE_API_KEY=sk-ant-...
NODE_ENV=production

# ============ MEDIA STORAGE (required for any media agent) ============
# Meta/YouTube/LinkedIn publish by FETCHING a public URL — generated media
# must be hosted somewhere reachable. Cloudinary free tier is plenty.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============ IMAGE + SUBTITLE (OpenAI) ============
# Used by: image_agent, thumbnail_agent (gpt-image-1), subtitle_agent (whisper-1)
OPENAI_API_KEY=sk-...

# ============ VOICE (ElevenLabs) ============
# elevenlabs.io -> sign up (free tier: ~10 min audio/month) -> Profile -> API key
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=       # optional; pick a voice in Voice Library and paste its ID
VOICE_LANGUAGE=en          # en | hi (Hinglish scripts work fine with either)

# ============ VIDEO ============
# Option 0 (CHEAPEST): fal.ai — one key, many budget models (Kling / Wan /
# Seedance / Hailuo), typically $0.03-0.05 per second. fal.ai -> Dashboard -> Keys.
# Takes priority over Veo when set. Model IDs shift often, so it's an env var:
# browse fal.ai/models, copy the model id, paste below. Needs CREATOMATE_API_KEY
# to stitch multiple shots with the voiceover.
FAL_KEY=
FAL_MODEL=fal-ai/kling-video/v2/standard/text-to-video
FAL_SCENES=3
FAL_DURATION=5
FAL_COST_PER_SECOND=0.04   # only used to estimate spend in the dashboard

# Option A (best quality): Google Veo via Gemini API — generates REAL cinematic
# footage from the script (no avatar, no static image). aistudio.google.com -> Get API key.
# Claude storyboards the script into 8s shots, Veo renders each, Creatomate stitches
# them with the ElevenLabs voiceover + subtitles (so CREATOMATE_API_KEY is needed too).
# COST WARNING: Veo bills per second of video.
#   veo-3.1-fast-generate-preview  ~$0.15/s -> ~$1.20 per 8s shot -> ~$3.60 per 3-shot reel
#   veo-3.1-generate-preview       ~$0.40/s -> ~$3.20 per 8s shot -> ~$9.60 per 3-shot reel
# Start with fast + 2 scenes to keep costs sane.
GEMINI_API_KEY=
VEO_MODEL=veo-3.1-fast-generate-preview
VEO_SCENES=3               # number of 8s shots (3 => ~24s reel)
VEO_RESOLUTION=720p        # 720p | 1080p

# Option A (recommended): HeyGen — a talking AI presenter speaks your script,
# lip-synced to the ElevenLabs voiceover. heygen.com -> Settings -> API.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=          # optional; copy any avatar's ID from HeyGen, else first avatar is used

# Option B (fallback): Creatomate — image slideshow + voiceover + subtitles.
# If both keys are set, HeyGen (avatar) is used.
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_ID=    # optional; falls back to an inline 9:16 composition

# ============ META (Instagram + Facebook + Competitor + Analytics) ============
META_GRAPH_API_TOKEN=          # long-lived token, needs instagram_content_publish
META_IG_BUSINESS_ID=           # IG Business account id
META_PAGE_ACCESS_TOKEN=        # PAGE token (not user token) for Facebook
META_PAGE_ID=
COMPETITOR_HANDLES=            # comma-separated, e.g. handle1,handle2

# ============ YOUTUBE SHORTS ============
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ============ LINKEDIN ============
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# ============ WHATSAPP (WATI) ============
WATI_API_KEY=
WATI_BASE_URL=https://live-server-xxxxx.wati.io

# ============ DASHBOARD (required - app is on a public URL) ============
DASHBOARD_PASSWORD=choose-a-strong-password
DASHBOARD_SECRET=any-long-random-string-for-signing-cookies
